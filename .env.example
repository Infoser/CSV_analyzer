# AI API Configuration
# Choose ONE provider: NVIDIA NIM (recommended) OR OpenAI-compatible API

# ============================================
# NVIDIA NIM (Recommended - Free tier available)
# Get API key from: https://build.nvidia.com/explore/discover
# ============================================
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct

# ============================================
# OpenAI / OpenAI-Compatible API (Alternative)
# ============================================
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ============================================
# Optional: App Configuration
# ============================================
# NEXT_PUBLIC_APP_URL=http://localhost:3000